# Penguin 环境变量配置示例
# 复制此文件为 .env 并填入你的API密钥

# ===========================================
# 默认模型 (LiteLLM格式: provider/model)
# ===========================================
# Z.AI (智谱): zai/glm-4.7, zai/glm-4.5-flash (免费), zai/glm-4.5
# Anthropic: anthropic/claude-3-5-sonnet, anthropic/claude-3-opus
# OpenAI: openai/gpt-4o, openai/gpt-4-turbo, openai/gpt-3.5-turbo
# DeepSeek: deepseek/deepseek-chat, deepseek/deepseek-coder
# Ollama: ollama/llama3, ollama/qwen2

MODEL=zai/glm-4.5-flash

# ===========================================
# API Keys (LiteLLM自动识别)
# ===========================================
ZAI_API_KEY=your-zai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here

# ===========================================
# 自定义API端点 (可选，用于代理或兼容API)
# ===========================================
# ANTHROPIC_BASE_URL=https://your-proxy.com
# OPENAI_BASE_URL=https://your-proxy.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===========================================
# 工具配置
# ===========================================
# Bash命令超时时间(秒)
BASH_TIMEOUT=120
